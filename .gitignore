# Python (in case anyone scripts something locally)
__pycache__/
*.pyc
.venv/
venv/

# Generated patches and headers (regeneratable from .gpatch sources you choose to commit)
generated/
*.h.gen

# Local scratch / experiments
scratch/
tmp/
*.local.html
*.local.gpatch

# Logs and dumps
*.log

# Local-only design docs (SPEC.md / EXPANSION.md / OPTIONS.md).
