.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# Editors / IDEs
.vscode/
.idea/
*.swp
*.swo
*~
.cursor/
.aider*

# Claude Code local settings (keep CLAUDE.md tracked)
